# Configuración local para capturador PJN.
# Copiar a .env.pjn.capture, completar credenciales y proteger con chmod 600.
#
# NO commitear .env.pjn.capture.

PJN_USERNAME=
PJN_PASSWORD=

PJN_START_URL=https://scw.pjn.gov.ar/scw/consultaListaRelacionados.seam

PJN_SELECTOR_USERNAME=#username
PJN_SELECTOR_PASSWORD=#password
PJN_SELECTOR_LOGIN_BUTTON=#kc-login

# Cámara/fuero.
# Valores detectados:
# CIV=1
# CAF=2
# CCF=3
# CSS=5
# CPE=6
# CNT=7
# CFP=8
# CCC=9
# COM=10
# FCB=15
# FGR=17
# FLP=18
# FMZ=20
# FPA=22
# FSM=26
PJN_SELECTOR_SEARCH_CAMARA=select[id$=':consultaExpediente:camara']
PJN_CAMARA_VALUE=

PJN_SELECTOR_SEARCH_NUMERO=input[id$=':numero']
PJN_SELECTOR_SEARCH_ANIO=input[id$=':anio']
PJN_SELECTOR_SEARCH_BUTTON=input[id$=':consultaFiltroSearchButtonSAU']

PJN_SELECTOR_RESULT_LINK=a:has-text("visualizar expediente:")

PJN_SELECTOR_EXPEDIENTE_READY=table[id$=':action-table']

# Incluye documentos normales por viewer.seam y tasa de justicia por documentTasaJusticia.seam.
PJN_SELECTOR_ROWS=table[id$=':action-table'] tr:has(a[href*='viewer.seam']), table[id$=':action-table'] tr:has(a[href*='documentTasaJusticia.seam'])
PJN_SELECTOR_ROW_FECHA=td:nth-child(3)
PJN_SELECTOR_ROW_DESCRIPCION=td:nth-child(5)
PJN_SELECTOR_ROW_PDF=a[href*='viewer.seam'][href*='download=true'], a[href*='documentTasaJusticia.seam']

PJN_SELECTOR_VIEWER_DOWNLOAD=
PJN_SELECTOR_CAPTCHA=
